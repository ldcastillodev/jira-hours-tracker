{
  "buildCommand": "turbo run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "functions": {
    "api/[...path].ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "regions": ["iad1"],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
