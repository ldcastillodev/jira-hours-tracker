generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            Int         @id @default(autoincrement())
  name          String
  monthlyBudget Float       @map("monthly_budget")
  components    Component[]
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("projects")
}

model Component {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  isBillable Boolean   @map("is_billable")
  projectId  Int       @map("project_id")
  project    Project   @relation(fields: [projectId], references: [id])
  worklogs   Worklog[]
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("components")
}

model Developer {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  jiraAccountId String   @unique @map("jira_account_id")
  slackId       String?  @unique @map("slack_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("developers")
}

model Worklog {
  id            Int       @id @default(autoincrement())
  hours         Float
  date          DateTime  @db.Date
  jiraIssueId   String    @unique @map("jira_issue_id")
  jiraAccountId String    @map("jira_account_id")
  componentId   Int       @map("component_id")
  component     Component @relation(fields: [componentId], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([componentId, date])
  @@index([jiraAccountId, date])
  @@map("worklogs")
}

