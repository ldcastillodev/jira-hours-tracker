generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            Int         @id @default(autoincrement())
  name          String
  monthlyBudget Float?      @map("monthly_budget")
  components    Component[]
  deletedAt     DateTime?   @map("deleted_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("projects")
}

model Component {
  id         Int       @id @default(autoincrement())
  name       String
  isBillable Boolean   @map("is_billable")
  projectId  Int       @map("project_id")
  project    Project   @relation(fields: [projectId], references: [id])
  worklogs   Worklog[]
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("components")
}

model Developer {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  slackId   String?   @unique @map("slack_id")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("developers")
}

model Worklog {
  id             Int       @id @default(autoincrement())
  jiraWorklogId  String    @unique @map("jira_worklog_id")
  ticketKey      String    @map("ticket_key")
  hours          Float
  date           DateTime  @db.Date
  assigned       String
  componentId    Int       @map("component_id")
  component      Component @relation(fields: [componentId], references: [id])
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([componentId, date])
  @@index([assigned, date])
  @@index([ticketKey])
  @@index([date])
  @@map("worklogs")
}

