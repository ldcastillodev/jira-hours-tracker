# Database (Neon PostgreSQL)
# Use the pooled connection string (pgbouncer) for the app
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/mgs_clients?sslmode=require&pgbouncer=true&connect_timeout=15"
# Use the direct (non-pooled) connection for migrations and Prisma Studio
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/mgs_clients?sslmode=require"

# Jira Integration
JIRA_BASE_URL="https://your-domain.atlassian.net"
JIRA_EMAIL="your-email@example.com"
JIRA_API_TOKEN="your-jira-api-token"

# Local development only
API_PORT=3001
CORS_ORIGIN="http://localhost:5173"
